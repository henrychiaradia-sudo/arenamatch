# =========================================================================
# ArenaMatch — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores.
# NUNCA versione o `.env.local`. Nunca exponha chaves secretas no frontend.
# =========================================================================

# --- Supabase (obrigatório) -----------------------------------------------
# Encontre em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Chave de service role — SOMENTE no servidor (jamais no client).
# Usada por scripts administrativos/seed. Deixe em branco se não usar.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Aplicação ------------------------------------------------------------
# URL pública do app (usada em e-mails, callbacks de auth, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Marca (permite trocar o nome do produto sem tocar no código)
NEXT_PUBLIC_APP_NAME="ArenaMatch"

# --- E-mail (preparado para o futuro) -------------------------------------
# Notificações por e-mail estão desativadas no MVP. Deixe como está.
EMAIL_ENABLED="false"

# --- Ambiente -------------------------------------------------------------
NODE_ENV="development"
